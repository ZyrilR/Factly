<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomSheetTopics"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_top_white"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp"
    android:elevation="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Favorite Topics"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Select the categories you want to see in your fact feed.\nYou can change these anytime."
        android:textColor="#666666"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4" />

    <GridLayout
        android:id="@+id/gridTopics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:columnCount="3"
        android:useDefaultMargins="false" />

    <Button
        android:id="@+id/btnApply"
        android:layout_width="320dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:layout_gravity="center"
        android:background="@drawable/button_rounded_yellow"
        app:backgroundTint="@null"
        android:text="Apply"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="320dp"
        android:layout_height="50dp"
        android:layout_marginTop="6dp"
        android:layout_gravity="center"
        android:background="@drawable/button_rounded_white"
        app:backgroundTint="@null"
        android:text="Back"
        android:textColor="#333333"
        android:textSize="16sp" />

</LinearLayout>