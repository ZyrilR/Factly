<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#00000066"
    android:gravity="center">

    <!-- Card overlay matching prototype -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:layout_marginHorizontal="24dp"
        android:padding="24dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Your Favorite Topics"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select the categories you want to see in your fact feed.\nYou can change these anytime."
            android:textColor="#666666"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.4" />

        <!-- Topic chips injected here by code -->
        <GridLayout
            android:id="@+id/gridTopics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="3"
            android:useDefaultMargins="false" />

        <Button
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FFD54F"
            android:text="Apply"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="Back"
            android:textColor="#333333"
            android:textSize="15sp"
            android:strokeColor="#E0E0E0"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>
</LinearLayout>
