<?xml version="1.0" encoding="utf-8"?>
<!-- Fact Detail Overlay — centered dialog with white rounded card -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="48dp">

        <LinearLayout
            android:id="@+id/cardFactDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_detail_bg"
            android:elevation="16dp"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Topic badge row: badge left, unfavorite star right -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/textViewDetailTopic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/badge"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imageViewDetailStar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_star_filled"
                    android:padding="2dp" />

            </RelativeLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:background="#EEEEEE" />

            <!-- Fact content -->
            <TextView
                android:id="@+id/textViewDetailFact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.6"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- "Did you know?" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Did you know?"
                android:textColor="#FFD54F"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Expanded info -->
            <TextView
                android:id="@+id/textViewDetailExpanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.7"
                android:textColor="#444444"
                android:textSize="14sp" />

            <!-- Close button -->
            <Button
                android:id="@+id/buttonCloseDetail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#FFD54F"
                android:text="Got it!"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>