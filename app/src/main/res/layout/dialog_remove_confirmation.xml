<?xml version="1.0" encoding="utf-8"?>
<!-- Remove Confirmation Overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <LinearLayout
        android:id="@+id/cardRemoveConfirm"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/card_detail_bg"
        android:elevation="16dp"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Icon -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_star_filled"
            android:alpha="0.6" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Remove from Favorites?"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="This fact will be removed\nfrom your saved list."
            android:textColor="#888888"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" />

        <!-- Remove button -->
        <Button
            android:id="@+id/buttonConfirmRemove"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FF5252"
            android:text="Remove"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- Cancel button -->
        <Button
            android:id="@+id/buttonCancelRemove"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#FFFFFF"
            android:text="Cancel"
            android:textColor="#333333"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp" />

    </LinearLayout>

</FrameLayout>