<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="40dp"
    android:background="#FFFFFF">

    <!-- Header: logo from Factly design -->
    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:layout_marginTop="60dp"
        android:layout_gravity="start"
        android:layout_marginStart="-12dp"
        android:adjustViewBounds="true"
        android:src="@drawable/logo" />

    <!-- Welcome text -->
    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Welcome!"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Topic label -->
    <TextView
        android:id="@+id/textviewTopic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textSize="12sp"
        android:textColor="#FFD54F"
        android:textStyle="bold" />

    <!-- Fact card -->
    <TextView
        android:id="@+id/textviewFact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/button_rounded"
        android:padding="20dp"
        android:textSize="16sp"
        android:textColor="#333333"
        android:lineSpacingMultiplier="1.4"
        android:elevation="1dp"
        android:translationZ="1dp" />

    <!-- Action buttons -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:backgroundTint="#FFD54F"
        android:text="Save to Favorites"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:elevation="1dp"
        android:translationZ="2dp" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#FFD54F"
        android:text="Next Fact"
        android:textSize="14sp"
        android:elevation="1dp"
        android:translationZ="2dp" />

    <Button
        android:id="@+id/btnFavorites"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#FFD54F"
        android:text="View Favorites"
        android:textSize="14sp"
        android:elevation="1dp"
        android:translationZ="2dp" />

    <!-- Nav buttons from Factly design -->
    <Button
        android:id="@+id/buttonProfile"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:backgroundTint="#FFD54F"
        android:text="Profile"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:elevation="1dp"
        android:translationZ="2dp" />

    <Button
        android:id="@+id/buttonLogout"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#FFD54F"
        android:text="Logout"
        android:textSize="14sp"
        android:elevation="1dp"
        android:translationZ="2dp" />

</LinearLayout>