<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top bar: logo + hamburger -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:scaleType="fitStart"
            android:src="@drawable/logo" />

        <ImageView
            android:id="@+id/imageViewMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/usericon"
            android:padding="2dp" />

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Your Fact for today!"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Fact card -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:elevation="2dp"
                    android:minHeight="180dp"
                    android:gravity="center"
                    android:padding="20dp"
                    android:paddingEnd="44dp">

                    <TextView
                        android:id="@+id/textviewFact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

                <!-- Star icon, top-right of card -->
                <ImageView
                    android:id="@+id/imageViewStar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:src="@drawable/usericon"
                    android:padding="2dp" />

            </FrameLayout>

            <!-- Topic badge below card -->
            <TextView
                android:id="@+id/textviewTopic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/badge_food"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <!-- Next Fact button -->
            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#FFD54F"
                android:text="Next Fact  ›"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/usericon" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Home" android:textSize="11sp"
                android:textColor="#000000" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFavorites"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/usericon" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Favorites" android:textSize="11sp"
                android:textColor="#AAAAAA" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/usericon" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="Profile" android:textSize="11sp"
                android:textColor="#AAAAAA" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>